# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# App URLs
APP_BASE_URL=http://localhost:3000
VSCODE_CALLBACK_URI=vscode://prmpt.prmpt/auth-callback

# Clerk (Auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
CLERK_JWT_TEMPLATE=supabase
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx
CLERK_SIGN_IN_URL=http://localhost:3000/sign-in
CLERK_SIGN_UP_URL=http://localhost:3000/sign-up

# Supabase (Cloud metadata store)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxx

# Polar (Payments)
POLAR_ENV=sandbox
POLAR_ACCESS_TOKEN=oat_xxxxxxxxxxxxxxxxx
POLAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx
POLAR_PRODUCT_ID=prod_xxxxxxxxxxxxxxxxx
POLAR_PRICE_ID=price_xxxxxxxxxxxxxxxxx
POLAR_BENEFIT_KEY=prmpt_premium
POLAR_SUCCESS_URL=http://localhost:3000/api/v1/payment/success
POLAR_CANCEL_URL=http://localhost:3000/api/v1/payment/cancel

# BYOK Providers
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxx

# Ollama (Local premium mode)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Telemetry
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=http://localhost:3000/api/v1/telemetry/events
