{
  "name": "@prmpt/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint ok: @prmpt/web')\"",
    "test": "pnpm --filter @prmpt/contracts run build && pnpm --filter @prmpt/data-access run build && pnpm run build && node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "@prmpt/contracts": "workspace:*",
    "@prmpt/data-access": "workspace:*",
    "@prmpt/shared-utils": "workspace:*"
  }
}
